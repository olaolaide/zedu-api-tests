  },
  "homepage": "https://github.com/olaolaide/zedu-api-tests#readme",
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "ajv": "^8.13.0",
    "ajv-formats": "^3.0.1",
    "dotenv": "^16.4.5",
    "faker": "^5.5.3",
    "@faker-js/faker": "^8.4.1",
    "json-schema-generator": "^1.1.1"
  }
