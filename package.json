{
  "name": "zedu-api-tests",
  "version": "1.0.0",
  "description": "**Automated API Testing Framework (JavaScript • Playwright • Dotenv)**",
  "main": "index.js",
  "scripts": {
    "test:api": "playwright test --project=api",
    "test:ui": "playwright test --project=ui",
    "test:all": "playwright test",
    "test:dev": "API_ENV=dev playwright test --project=api",
    "test:qa": "API_ENV=qa playwright test --project=api",
    "test:prod": "API_ENV=prod playwright test --project=api",
    "report": "playwright show-report",
    "schema:generate": "node src/utils/schema/schema-generator.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/olaolaide/zedu-api-tests.git"
  },
